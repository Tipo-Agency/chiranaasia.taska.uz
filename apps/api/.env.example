# Локальный запуск apps/api (без Docker): скопируйте в apps/api/.env
# Все три переменные обязательны — без них приложение не стартует.

DATABASE_URL=postgresql+asyncpg://taska:taska@localhost:5433/taska
REDIS_URL=redis://localhost:6379/0
# >= 32 символа; не использовать подстроки change-me, placeholder и т.п.
SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Опционально: лимит длительности одного SQL на соединениях API/воркеров (мс). Alembic не затрагивает.
# DATABASE_STATEMENT_TIMEOUT_MS=60000

# Только явные URL через запятую; '*' нельзя (с cookies / credentials браузер это не примет).
# В проде добавьте origin SPA, например: https://tipa.taska.uz — либо задайте PUBLIC_BASE_URL ниже (его origin подмешивается в CORS/CSRF).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Access-Control-Allow-Credentials — выключите, если фронт без cookie-сессии к API.
CORS_ALLOW_CREDENTIALS=true
CALENDAR_EXPORT_TZID=Asia/Tashkent

# Redis Streams (опционально; дефолты в app/core/config.py — queue.*.v1, см. docs/QUEUES.md)
# REDIS_EVENTS_STREAM=queue.domain.v1
# REDIS_INTEGRATIONS_STREAM=queue.integrations.v1
# REDIS_NOTIFICATIONS_STREAM=queue.notifications.v1
# DOMAIN_EVENTS_HUB_ASYNC=false  # true + workers.domain_events_worker — hub вне HTTP
# WEBSOCKET_MAX_CONNECTIONS_PER_USER=20
# SENTRY_DSN=
# PROMETHEUS_SCRAPE_TOKEN=   # Bearer для GET /metrics с внешних IP; пусто — только localhost
# ENVIRONMENT=development   # production | staging — см. валидацию CSRF в config
# Публичный URL приложения (без хвоста /api). Добавляет origin в CORS и разрешает CSRF для same-origin за nginx.
# PUBLIC_BASE_URL=https://tipa.taska.uz

# S3 / медиа вложений (пусто — без S3):
# S3_BUCKET=  S3_REGION=us-east-1  AWS_ACCESS_KEY_ID=  AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=   # MinIO и др.
# SMTP_HOST=  SMTP_USER=  SMTP_PASSWORD=

# Безопасность сессии (по умолчанию в коде уже безопасные значения):
# AUTH_ALLOW_BEARER_HEADER=false — JWT только из cookie; true — для скриптов с Bearer.
# access_token / refresh_token в теле ответа login/refresh не отдаются — только Set-Cookie (HttpOnly); csrf_token — не HttpOnly (читается фронтом).
# CSRF_PROTECTION_ENABLED=false — только для локальной отладки (ENVIRONMENT=development). В production/prod/staging выключить CSRF нельзя — приложение не стартует.
