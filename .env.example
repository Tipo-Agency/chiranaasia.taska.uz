# Скопируйте в .env в корне репозитория (не коммитить).
# Backend (docker-compose → сервис backend). Полный список ключей приложения: docs/OPERATIONS.md §9 и apps/api/app/core/config.py
DB_PASSWORD=taska
# Обязательно: >= 32 символа, не использовать шаблоны вроде change-me (валидация в apps/api).
# Пример для локальной разработки (замените на свой случайный ключ):
SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Telegram Bot (для docker-compose)
# TELEGRAM_BOT_TOKEN=your-bot-token

# Опционально для backend/воркеров (прокинуть в compose при необходимости):
# DATABASE_STATEMENT_TIMEOUT_MS=60000
# ENVIRONMENT=production
# CORS_ORIGINS=https://chiranaasia.taska.uz
# COOKIE_SECURE=1

# Frontend (apps/web) — опционально
# VITE_API_URL=http://localhost:8000/api
# Локальный сид mockData в localStorage (только npm run dev): true | 1
# VITE_ENABLE_DEMO_SEED=true
# Instagram / лиды Meta (будущая интеграция): true | 1
# VITE_ENABLE_INSTAGRAM_LEADS=false
