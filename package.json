{
  "name": "tipa-taska",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "preview:web": "npm --workspace apps/web run preview",
    "types:api": "openapi-typescript http://localhost:8000/openapi.json -o apps/web/types/api.d.ts",
    "docker:up": "docker-compose up -d",
    "docker:tools": "docker-compose --profile tools up -d",
    "deploy": "git push origin main",
    "push": "git push origin main",
    "lint:web": "npm --workspace apps/web run lint",
    "ci:web": "npm --workspace apps/web run lint && npm --workspace apps/web run typecheck && npm --workspace apps/web run build"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}
